{
  "name": "promptcontract",
  "version": "0.1.0",
  "description": "Local-first prompt contract lint and validation CLI.",
  "type": "module",
  "bin": {
    "promptcontract": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "fixtures",
    "docs",
    "SKILL.md",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "dev": "tsx src/cli.ts",
    "test": "node --test dist/**/*.test.js",
    "smoke": "node dist/cli.js check fixtures/pass/*.md && node dist/cli.js check fixtures/fail/*.md --report json --output tmp/fail-report.json; test $? -eq 1",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run build && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "prompt",
    "lint",
    "cli",
    "contracts",
    "ai"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fast-glob": "^3.3.3",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/promptcontract.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/promptcontract/issues"
  },
  "homepage": "https://github.com/rogerchappel/promptcontract#readme"
}
